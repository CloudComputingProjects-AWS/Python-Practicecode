import threading
import time

def brew_chai():
    print(f"{threading.current_thread().name} is brewing chai...")
    count=0
    for _ in range(10000000):
        count+=1
    print(f"{threading.current_thread().name} finished brewing chai...")

barista1=threading.Thread(target=brew_chai, name="Thread-1")
barista2=threading.Thread(target=brew_chai, name="Thread-2")
start=time.time()
barista1.start()
barista2.start()
barista1.join()
barista2.join()
end=time.time()
print(f"Total time taken: {end-start:.2f} seconds")
